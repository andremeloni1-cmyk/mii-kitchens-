# Copy to .env and fill in. NEVER commit the real .env.

# --- Server ---
PORT=3000
NODE_ENV=production
# Long random string used to sign session cookies.
SESSION_SECRET=change-me-to-a-long-random-string
# Set to 1 when served over HTTPS (nginx / managed host) so the cookie is Secure.
COOKIE_SECURE=1

# Managed/no-shell hosting (e.g. Hostinger Git import): set to 1 so the app
# creates/upgrades the MySQL tables on boot (db/schema.sql is idempotent).
# Leave unset on a VPS where you import the schema yourself.
AUTO_MIGRATE=0

# One-time setup. Set a long random value to enable /setup.html (set the first
# admin password from the browser when you have no terminal). REMOVE it again
# once you've signed in. Leave unset/empty to disable the setup route entirely.
SETUP_TOKEN=

# --- MySQL (on the VPS) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=mii_hub
DB_PASSWORD=change-me
DB_NAME=mii_hub

# --- Apps Script sync ---
# Shared secret the Google Apps Script must send in the X-Sync-Secret header
# when POSTing to /api/sync. Generate a long random value and set the same
# value in the Apps Script Script Properties (SYNC_SECRET).
SYNC_SECRET=change-me-to-a-long-random-string
